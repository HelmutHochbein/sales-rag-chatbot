# This file includes environment variables that can be committed to git.
# It's gitignored by default because it represents your local development environment.

# Built-in environment variables
TEAMSFX_ENV=dev
APP_NAME_SUFFIX=local

# Generated during provision – leave empty, will be filled by Teams Toolkit
BOT_ID=00000000-0000-0000-0000-000000000003
TEAMS_APP_ID=
BOT_DOMAIN=salesbot.azurewebsites.net
BOT_ENDPOINT=https://salesbot.azurewebsites.net
SECRET_BOT_PASSWORD=

# === Microsoft Bot ===
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
PORT=3978
MICROSOFT_APP_TYPE=SingleTenant
MICROSOFT_APP_TENANT_ID=00000000-0000-0000-0000-000000000002

# Pfad zur JSON-Vorlage
PROMPT_REQUEST_JSON=./config/prompt_request.json

# === Anthropic (Messages API) ===
# IMPORTANT: Set your Anthropic API key here (do not commit real keys!)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# === Notion (direkter API-Zugriff) ===
# Integration-Token aus https://www.notion.so/profile/integrations.
# Achtung: jede Page/Database muss explizit für die Integration freigegeben sein.
NOTION_TOKEN=
NOTION_ROOT_PAGE_ID=

# === Web Search ===
WEBSEARCH_ENABLED=true
WEBSEARCH_DOMAINS=manufacturer-docs.example.com,example-company.de
WEBSEARCH_COUNTRY=Germany
WEBSEARCH_REGION=
WEBSEARCH_CITY=
WEBSEARCH_TIMEZONE=Europe/Berlin
WEBSEARCH_CONTEXT_SIZE=medium

# === Azure Table Storage (Conversation State) ===
# Lokal: Azurite oder echter Storage Account via Connection String.
# In Azure: AZURE_USE_MANAGED_IDENTITY=1 + AZURE_TABLE_ENDPOINT (kein Conn-String).
AZURE_TABLE_ENDPOINT=
AZURE_TABLE_NAME=BotConversations
AZURE_USE_MANAGED_IDENTITY=0
AZURE_TABLE_CONNECTION_STRING=

# === Azure – filled during provision ===
RESOURCE_SUFFIX=
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000001
AZURE_RESOURCE_GROUP_NAME=acmeco-chatbot-sales
TEAMS_APP_TENANT_ID=
BOT_AZURE_APP_SERVICE_RESOURCE_ID=/subscriptions/00000000-0000-0000-0000-000000000001/resourceGroups/acmeco-chatbot-sales/providers/Microsoft.Web/sites/salesbot
BOT_TENANT_ID=00000000-0000-0000-0000-000000000002
TEAMS_APP_PUBLISHED_APP_ID=
