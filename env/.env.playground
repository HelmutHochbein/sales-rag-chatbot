# This file includes environment variables that can be committed to git.

# Built-in environment variables
TEAMSFX_ENV=playground

# Environment variables used by Microsoft 365 Agents Playground
TEAMSAPPTESTER_PORT=56150
TEAMSFX_NOTIFICATION_STORE_FILENAME=.notification.playgroundstore.json

# === Microsoft Bot ===
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
PORT=3978

# === Anthropic (Messages API) ===
# IMPORTANT: Set your Anthropic API key here (do not commit real keys!)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# === Notion (direkter API-Zugriff) ===
NOTION_TOKEN=
NOTION_ROOT_PAGE_ID=

# === Web Search ===
WEBSEARCH_ENABLED=true
WEBSEARCH_DOMAINS=manufacturer-docs.example.com,example-company.de
WEBSEARCH_COUNTRY=Germany
WEBSEARCH_REGION=
WEBSEARCH_CITY=
WEBSEARCH_TIMEZONE=Europe/Berlin
WEBSEARCH_CONTEXT_SIZE=medium

# === Azure Table Storage (Conversation State) ===
AZURE_TABLE_ENDPOINT=
AZURE_TABLE_NAME=BotConversations
AZURE_USE_MANAGED_IDENTITY=0
AZURE_TABLE_CONNECTION_STRING=
