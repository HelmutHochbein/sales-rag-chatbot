{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.23/MicrosoftTeams.schema.json",
    "manifestVersion": "1.23",
    "version": "1.0.0",
    "id": "00000000-0000-0000-0000-000000000004",
    "developer": {
        "name": "AcmeCo GmbH",
        "websiteUrl": "https://www.example-company.de",
        "privacyUrl": "https://www.example-company.de/datenschutz",
        "termsOfUseUrl": "https://www.example-company.de/agb"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "AcmeCo Sales",
        "full": "AcmeCo Sales Bot"
    },
    "description": {
        "short": "KI-Assistent für den Außendienst",
        "full": "Ihr persönlicher KI-Assistent für Vertriebsaußendienst-Fragen bei AcmeCo."
    },
    "accentColor": "#228B22",
    "bots": [
        {
            "botId": "00000000-0000-0000-0000-000000000003",
            "scopes": [
                "personal",
                "team",
                "groupChat"
            ],
            "supportsFiles": false,
            "isNotificationOnly": false,
            "commandLists": [
                {
                    "scopes": ["personal", "team", "groupChat"],
                    "commands": [
                        {
                            "title": "Wie kannst du mir helfen?",
                            "description": "Zeigt, womit der Bot dir helfen kann"
                        },
                        {
                            "title": "Welche Produkte bietet AcmeCo an?",
                            "description": "Übersicht der AcmeCo Produkte und Leistungen"
                        },
                        {
                            "title": "Was muss ich bei der Umsetzung beachten?",
                            "description": "Allgemeine Hinweise zur technischen Umsetzung"
                        }
                    ]
                }
            ]
        }
    ],
    "composeExtensions": [],
    "configurableTabs": [],
    "staticTabs": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": [
        "salesbot.azurewebsites.net"
    ]
}
